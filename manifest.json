{
  "manifest_version": 3,
  "name": "Clickbaitometr",
  "version": "1.0",
  "description": "Wykrywa manipulację i clickbaity na stronach internetowych.",
  
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "host_permissions": [
    "https://wtyczka-ebon.vercel.app/*" 
  ]
}